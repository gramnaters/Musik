# Local: copy to `.env.local`. Production (e.g. Render): add the same keys in Environment → Environment Variables.

# Spotify Web API (client credentials) — used for catalog search, playlist import, and metadata when Spotify is selected in Settings.
# Create an app at https://developer.spotify.com/dashboard — no redirect URI needed for client-credentials flows.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
